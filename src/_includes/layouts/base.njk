<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <title>{% if '/' === page.url %}V8 JavaScript engine{% else %}{{ (renderData.title or title) | markdown | striptags | decodeHtmlEntities }} · V8{% endif %}</title>
    <meta name="viewport" content="width=device-width">
    <meta name="color-scheme" content="dark light">
    <meta name="google-site-verification" content="_id9bpWau5RTqOu8c_2VMC6eLoMuXZyZqQWhDVvA8IY" />
    <link rel="stylesheet" href="/_css/main.css">
    <!-- Cloudflare Web Analytics --><script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "09eab08927f84988a043ec439f5d8cb3"}'></script><!-- End Cloudflare Web Analytics -->
{% if '/features' in page.url %}
    <link rel="stylesheet" href="/_css/feature-support.css">
{% endif %}
    <link rel="icon" href="/favicon.png" sizes="48x48">
    <link rel="manifest" href="/.webmanifest">
    <meta name="theme-color" content="#4285F4">
    <link rel="alternate" href="{{ metadata.feed.path | url }}" type="application/atom+xml" title="V8 Atom feed">
    <link rel="alternate" href="/features.atom" type="application/atom+xml" title="V8 JS/Wasm features Atom feed">
{% for extra_link in extra_links %}
    <link rel="{{ extra_link.rel }}" href="{{ extra_link.href }}">
{% endfor %}
    <script>document.documentElement.className+=' js'</script>
{% if description %}
    <meta name="description" content="{{ description }}">
{% endif %}
  </head>
  <body>
    <header id="header">
      <h1><a href="/">V8</a></h1>
      <a href="#navigation-toggle" id="nav-toggle">Show navigation</a>
      <nav>
        <ul>
          <li{% if '/' === page.url %} class="current"{% endif %}><a href="/">Home</a></li>
          <li{% if '/blog' in page.url %} class="current"{% endif %}><a href="/blog">Blog</a></li>
 <li{% if '/features' in page.url %} class="current"{% endif %}><a href="/features" title="Features">Features</a></li>
          <li{% if '/grant' in page.url %} class="current"{% endif %}><a href="/grant">Research</a></li>
        </ul>
      </nav>
    </header>
    <main id="main">
      {{ content | safe }}
    </main>
    <footer id="footer">
      <div>
        <nav>
          <a href="/terms">Terms</a>
          <a href="/privacy">Privacy</a>
          <a href="https://x.com/praveenjpeg" rel="me nofollow">Twitter</a>
        </nav>
        <dark-mode-toggle permanent dark="Light Mode" light="Dark Mode"></dark-mode-toggle>
      </div>
      <p><small>&copy; 2026 Hunting For Kicks. All rights reserved. Release dates and retail prices are subject to change.</small></p>
    </footer>
    <script type="module" src="/_js/dark-mode-toggle.mjs"></script>
    <script src="/_js/main.js"></script>
  </body>
</html>
